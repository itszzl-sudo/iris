# Cargo 沙盒隔离配置
# 
# 使用方法：
# 1. 在项目根目录创建此文件
# 2. 根据操作系统运行相应的设置脚本
# 3. 所有 Cargo 操作将使用本地缓存，互不干扰

# 本地缓存目录
CARGO_HOME_LOCAL=.cargo-local
CARGO_TARGET_DIR_LOCAL=target

# 隔离的注册表缓存
CARGO_REGISTRY_CACHE=${CARGO_HOME_LOCAL}/registry
CARGO_REGISTRY_INDEX=${CARGO_HOME_LOCAL}/registry/index

# 隔离的全局配置
CARGO_HOME=${CARGO_HOME_LOCAL}

# 隔离的构建产物
CARGO_TARGET_DIR=${CARGO_TARGET_DIR_LOCAL}

# 禁用全局缓存共享
CARGO_NET_RETRY=3
CARGO_NET_TIMEOUT=30

# 日志级别（可选）
CARGO_LOG=cargo::core::compiler=info
